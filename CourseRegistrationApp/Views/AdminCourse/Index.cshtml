@model IEnumerable<CourseRegistrationApp.Models.Course>
@{
    ViewData["Title"] = "Quản lý học phần";
}

<div class="container py-4">
    <!-- Header banner -->
    <div class="bg-gradient bg-primary text-white rounded-4 p-4 p-md-5 mb-5 shadow d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <h1 class="display-5 fw-bold mb-2">Quản Lý Học Phần</h1>
            <p class="lead mb-0 text-white-50">Thêm mới, sửa đổi hoặc xóa các học phần giảng dạy trong hệ thống.</p>
        </div>
        <div>
            <a href="/admin/courses/create" class="btn btn-light btn-lg px-4 py-2.5 rounded-3 fw-bold text-primary shadow-sm hover-up transition-all">
                Thêm Học Phần Mới
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden bg-white">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light py-3 border-0">
                    <tr>
                        <th class="ps-4 py-3 text-secondary text-uppercase fs-7 fw-semibold">Hình ảnh</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-semibold">Tên học phần</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-semibold">Danh mục</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-semibold text-center">Tín chỉ</th>
                        <th class="py-3 text-secondary text-uppercase fs-7 fw-semibold">Giảng viên</th>
                        <th class="pe-4 py-3 text-secondary text-uppercase fs-7 fw-semibold text-end">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var course in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="rounded-3 overflow-hidden shadow-sm" style="width: 80px; height: 50px;">
                                    @if (!string.IsNullOrEmpty(course.Image))
                                    {
                                        <img src="/images/@course.Image" class="w-100 h-100 object-fit-cover" alt="@course.Name" onerror="this.onerror=null; this.src='https://placehold.co/120x80/0d6efd/ffffff?text=Course'" />
                                    }
                                    else
                                    {
                                        <img src="https://placehold.co/120x80/0d6efd/ffffff?text=Course" class="w-100 h-100 object-fit-cover" alt="@course.Name" />
                                    }
                                </div>
                            </td>
                            <td class="fw-semibold text-dark">@course.Name</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-1.5 rounded-pill fw-medium fs-8">
                                    @course.Category?.Name
                                </span>
                            </td>
                            <td class="text-center fw-bold">@course.Credits</td>
                            <td class="text-secondary">@course.Lecturer</td>
                            <td class="pe-4 text-end">
                                <a href="/admin/courses/edit/@course.Id" class="btn btn-outline-secondary btn-sm px-3 py-2 rounded-3 fw-semibold transition-all me-1">
                                    Sửa
                                </a>
                                <a href="/admin/courses/delete/@course.Id" class="btn btn-outline-danger btn-sm px-3 py-2 rounded-3 fw-semibold transition-all">
                                    Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .fs-7 {
        font-size: 0.8rem;
    }
    .fs-8 {
        font-size: 0.75rem;
    }
    .table > :not(caption) > * > * {
        padding: 1rem 0.5rem;
    }
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.02);
    }
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
    .hover-up:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 16px rgba(255, 255, 255, 0.2) !important;
    }
</style>
