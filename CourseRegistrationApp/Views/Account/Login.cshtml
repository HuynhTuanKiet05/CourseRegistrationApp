@model CourseRegistrationApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center align-items-center min-vh-75 mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden login-card">
            <div class="card-header bg-gradient bg-primary text-white text-center py-4 border-0">
                <h3 class="mb-1 fw-bold">ĐĂNG NHẬP HỆ THỐNG</h3>
                <p class="mb-0 text-white-50">Cổng đăng ký học phần sinh viên</p>
            </div>
            <div class="card-body p-5 bg-white">
                <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4 alert alert-danger border-0 rounded-3 small"></div>
                    
                    <div class="form-floating mb-3">
                        <input asp-for="Username" class="form-control rounded-3 border-light-subtle shadow-sm" placeholder="Tên đăng nhập" required />
                        <label asp-for="Username" class="text-secondary"></label>
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Password" type="password" class="form-control rounded-3 border-light-subtle shadow-sm" placeholder="Mật khẩu" required />
                        <label asp-for="Password" class="text-secondary"></label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input rounded border-light-subtle" />
                            <label asp-for="RememberMe" class="form-check-label text-secondary small"></label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold bg-gradient shadow hover-up transition-all mb-4">
                        ĐĂNG NHẬP
                    </button>
                </form>

                <div class="position-relative text-center my-4">
                    <hr class="text-muted opacity-25" />
                    <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">Hoặc đăng nhập bằng</span>
                </div>

                <div class="d-flex justify-content-center">
                    <form asp-action="ExternalLogin" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="w-100">
                        <button type="submit" name="provider" value="Google" class="btn btn-outline-danger w-100 py-2.5 rounded-3 d-flex align-items-center justify-content-center shadow-sm hover-up transition-all fw-medium">
                            <svg class="me-2" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
                                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                                <path fill="#4285F4" d="M46.5 24c0-1.55-.15-3.24-.47-4.78H24v9.09h12.75c-.53 2.87-2.13 5.31-4.57 6.95l7.13 5.53C43.51 36.11 46.5 30.65 46.5 24z"/>
                                <path fill="#FBBC05" d="M10.54 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.98-6.19z"/>
                                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.13-5.53c-2.11 1.41-4.8 2.29-8.76 2.29-6.26 0-11.57-4.22-13.46-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                            </svg>
                            Đăng nhập với Google
                        </button>
                    </form>
                </div>

                <div class="text-center mt-4">
                    <span class="text-muted small">Chưa có tài khoản?</span>
                    <a asp-action="Register" class="text-primary fw-bold text-decoration-none small ms-1 transition-all hover-underline">Đăng ký ngay</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

<style>
    .login-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-up:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(13, 110, 253, 0.2) !important;
    }
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
    .hover-underline:hover {
        text-decoration: underline !important;
    }
</style>
